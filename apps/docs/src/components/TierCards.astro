---
import { componentsNav, withBase } from "../lib/nav";

interface Props {
  base: string;
  tierLabel: string;
}

const { base, tierLabel } = Astro.props;
const tier = componentsNav.children?.find((t) => t.label === tierLabel);
---

{
  tier?.children && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 not-prose mt-8">
      {tier.children.map((item) => (
        <a
          href={withBase(base, item.href!)}
          class="block nvg-shadow-sm bg-card border border-border p-5 no-underline text-inherit rounded-lg transition-all duration-200 hover:scale-[1.02] hover:nvg-shadow-lg hover:border-primary/30"
          >
          <h3 class="text-primary m-0 text-lg font-semibold">{item.label}</h3>
        </a>
      ))}
    </div>
  )
}
