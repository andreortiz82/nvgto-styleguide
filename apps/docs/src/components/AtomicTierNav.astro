---
import { componentsNav, withBase } from "../lib/nav";

interface Props {
  base: string;
}

const { base } = Astro.props;
const tiers = componentsNav.children ?? [];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 not-prose my-8">
  {
    tiers.map((tier) => (
      <a
        href={withBase(base, tier.href!)}
        class="block nvg-shadow-sm bg-card border border-border p-6 no-underline text-inherit rounded-lg border-l-4 border-l-primary transition-all duration-200 hover:scale-[1.01] hover:nvg-shadow-lg hover:border-primary/40"
      >
        <p class="nvg-uppercase text-muted-foreground m-0 mb-1">Atomic Design</p>
        <h3 class="m-0 mb-2 font-semibold">{tier.label}</h3>
        <p class="text-sm text-muted-foreground m-0">{tier.description}</p>
      </a>
    ))
  }
</div>
