---
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout title="Typography">
  <h1>Typography</h1>
  <p>
    Raleway (800) for headings, Open Sans for body copy, Georgia for quotes and testimonials.
  </p>

  <div class="nvg-shadow-sm bg-white p-6 space-y-6 mt-6">
    <div>
      <h1>Heading 1 — Raleway 800</h1>
      <h2>Heading 2 — Raleway 800</h2>
      <h3>Heading 3 — Raleway 800</h3>
    </div>
    <p>Body text at 14px / 24px line height. Default for paragraphs, lists, and links.</p>
    <p class="nvg-lead">Lead paragraph — 18px for introductory copy on detail pages.</p>
    <p class="nvg-uppercase text-silver text-xs">Uppercase label style</p>
    <blockquote class="nvg-font-quote text-xl text-silver relative pl-5 border-l-4 border-brand">
      Quotes and testimonials use Georgia italic.
    </blockquote>
  </div>
</DocsLayout>
