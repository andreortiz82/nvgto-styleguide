---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { componentsNav, withBase } from "../../lib/nav";
import AtomicTierNav from "../../components/AtomicTierNav.astro";

const base = import.meta.env.BASE_URL;
---

<DocsLayout title="Components" description="Navigato component library organized by Atomic Design">
  <h1>Components</h1>
  <p class="nvg-lead">
    Navigato follows <strong>Atomic Design</strong> — atoms compose into molecules, molecules into
    organisms, and organisms into demoable pages. Each tier builds on the one below it.
  </p>

  <AtomicTierNav base={base} />

  <section class="mt-10 space-y-6">
    <h2>How the tiers map to travel UI</h2>
    <dl class="space-y-4">
      <div>
        <dt class="font-bold text-brand">Atoms</dt>
        <dd class="m-0 text-sm">
          Buttons, badges, labels, star ratings, and map pins — the smallest pieces that can't be
          broken down further without losing meaning.
        </dd>
      </div>
      <div>
        <dt class="font-bold text-brand">Molecules</dt>
        <dd class="m-0 text-sm">
          Form fields, cards, dropdowns, trip summaries, and price sliders — functional groups
          of atoms working together.
        </dd>
      </div>
      <div>
        <dt class="font-bold text-brand">Organisms</dt>
        <dd class="m-0 text-sm">
          Hotel cards, the SERP app bar, OTA rate lists, and focus windows — full interface
          sections users recognize instantly.
        </dd>
      </div>
      <div>
        <dt class="font-bold text-brand">Pages</dt>
        <dd class="m-0 text-sm">
          SERP and PDP templates — realistic compositions you can demo to stakeholders or use as
          integration references.
        </dd>
      </div>
    </dl>
  </section>

  <section class="mt-10">
    <h2>Browse by tier</h2>
    <ul class="list-none p-0 space-y-2">
      {
        componentsNav.children?.map((tier) => (
          <li>
            <a href={withBase(base, tier.href!)} class="text-brand font-bold no-underline hover:underline">
              {tier.label} →
            </a>
            <span class="text-silver text-sm ml-2">{tier.description}</span>
          </li>
        ))
      }
    </ul>
  </section>
</DocsLayout>
