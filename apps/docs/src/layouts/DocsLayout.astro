---
import { siteNav, withBase, isActive, type NavItem } from "../lib/nav";
import { MobileNav } from "../components/MobileNav";
import { ThemeToggle } from "../components/ThemeToggle";
import "@navigato/react/styles.css";

const base = import.meta.env.BASE_URL;
const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;

function itemActive(href?: string) {
  if (!href) return false;
  return isActive(currentPath, href, base);
}

function groupActive(item: NavItem) {
  if (item.href && itemActive(item.href)) return true;
  return item.children?.some(
    (child) =>
      itemActive(child.href) ||
      child.children?.some((grand) => itemActive(grand.href)),
  );
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? "Navigato design system documentation"} />
    <title>{title ? `${title} · Navigato` : "Navigato Design System"}</title>
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=SN+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="navigato-root min-h-screen bg-background text-foreground">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground focus:outline-none"
    >
      Skip to content
    </a>

    <header class="sticky top-0 z-40 flex items-center justify-between gap-3 border-b border-border bg-background/95 px-4 py-3 backdrop-blur supports-[backdrop-filter]:bg-background/80 lg:hidden">
      <a href={base} class="flex items-center gap-2 no-underline">
        <img src={`${base}logo-mark.svg`} alt="" width="28" height="28" class="shrink-0" />
        <span class="nvg-font-heading font-bold text-foreground tracking-tight">Navigato</span>
      </a>
      <div class="flex items-center gap-1">
        <ThemeToggle client:load />
        <MobileNav client:load base={base} currentPath={currentPath} />
      </div>
    </header>

    <div class="flex min-h-screen">
      <aside class="w-72 shrink-0 border-r border-sidebar-border bg-sidebar p-6 hidden lg:block sticky top-0 h-screen overflow-y-auto">
        <div class="flex items-start justify-between gap-2 mb-8">
          <a href={base} class="flex items-center gap-3 no-underline group min-w-0">
            <img
              src={`${base}logo-mark.svg`}
              alt=""
              width="36"
              height="36"
              class="shrink-0 transition-transform duration-200 group-hover:scale-105"
            />
            <div>
              <span class="nvg-font-heading font-bold text-lg text-foreground tracking-tight group-hover:text-primary transition-colors">
                Navigato
              </span>
              <span class="block text-xs text-muted-foreground font-medium">Design System</span>
            </div>
          </a>
          <ThemeToggle client:load />
        </div>
        <nav class="space-y-5 text-sm" aria-label="Documentation">
          {
            siteNav.map((item) =>
              item.children ? (
                <div>
                  <p class="nvg-uppercase text-muted-foreground mb-2">
                    {item.href ? (
                      <a
                        href={withBase(base, item.href)}
                        class:list={[
                          "no-underline",
                          itemActive(item.href) ? "text-primary" : "text-muted-foreground hover:text-primary",
                        ]}
                      >
                        {item.label}
                      </a>
                    ) : (
                      item.label
                    )}
                  </p>
                  <ul class="space-y-3 list-none p-0 m-0">
                    {item.children.map((child) => (
                      <li>
                        {child.children ? (
                          <div>
                            <a
                              href={child.href ? withBase(base, child.href) : undefined}
                              class:list={[
                                "block py-0.5 no-underline nvg-uppercase mb-1.5",
                                groupActive(child) ? "text-primary" : "text-foreground hover:text-primary",
                              ]}
                            >
                              {child.label}
                            </a>
                            <ul class="space-y-1 list-none p-0 m-0 pl-2 border-l border-border">
                              {child.children.map((grand) => (
                                <li>
                                  <a
                                    href={withBase(base, grand.href!)}
                                    class:list={[
                                      "block py-0.5 no-underline transition-colors text-sm",
                                      itemActive(grand.href)
                                        ? "text-primary font-bold"
                                        : "text-muted-foreground hover:text-primary",
                                    ]}
                                  >
                                    {grand.label}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          </div>
                        ) : (
                          <a
                            href={withBase(base, child.href!)}
                            class:list={[
                              "block py-0.5 no-underline transition-colors",
                              itemActive(child.href)
                                ? "text-primary font-bold"
                                : "text-foreground hover:text-primary",
                            ]}
                          >
                            {child.label}
                          </a>
                        )}
                      </li>
                    ))}
                  </ul>
                </div>
              ) : (
                <a
                  href={withBase(base, item.href!)}
                  class:list={[
                    "block py-1 no-underline transition-colors font-medium",
                    itemActive(item.href) ? "text-primary font-bold" : "text-foreground hover:text-primary",
                  ]}
                >
                  {item.label}
                </a>
              ),
            )
          }
        </nav>
      </aside>

      <main id="main-content" class="flex-1 p-6 lg:p-10 max-w-5xl">
        <div class="docs-prose">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
